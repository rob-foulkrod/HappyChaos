@model HappyChaos.Todo.Models.TodoTask
@using HappyChaos.Todo.Models
@{
    ViewData["Title"] = Model.Title;

    string PriorityBadgeClass(TaskPriority p) => p switch
    {
        TaskPriority.Critical => "badge-priority-critical",
        TaskPriority.High => "badge-priority-high",
        TaskPriority.Medium => "badge-priority-medium",
        _ => "badge-priority-low"
    };

    string StatusBadgeClass(HappyChaos.Todo.Models.TaskStatus s) => s switch
    {
        HappyChaos.Todo.Models.TaskStatus.InProgress => "badge-status-inprogress",
        HappyChaos.Todo.Models.TaskStatus.OnHold => "badge-status-onhold",
        HappyChaos.Todo.Models.TaskStatus.Completed => "badge-status-completed",
        _ => "badge-status-notstarted"
    };

    string StatusLabel(HappyChaos.Todo.Models.TaskStatus s) => s switch
    {
        HappyChaos.Todo.Models.TaskStatus.NotStarted => "Not Started",
        HappyChaos.Todo.Models.TaskStatus.InProgress => "In Progress",
        HappyChaos.Todo.Models.TaskStatus.OnHold => "On Hold",
        HappyChaos.Todo.Models.TaskStatus.Completed => "Completed",
        _ => s.ToString()
    };
}

<div class="page-header">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-1">
                <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Current Projects</a></li>
                <li class="breadcrumb-item active">Task Details</li>
            </ol>
        </nav>
        <h1 class="page-title">
            <i class="bi bi-clipboard-check me-2" style="color: var(--primary)"></i>Task Details
        </h1>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary d-flex align-items-center gap-2">
            <i class="bi bi-pencil"></i><span>Edit Task</span>
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary d-flex align-items-center gap-2">
            <i class="bi bi-arrow-left"></i><span>Back</span>
        </a>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card mb-4">
            <div class="card-body p-4">
                <div class="d-flex align-items-start gap-3 mb-3">
                    <div class="flex-grow-1">
                        <h2 class="h3 fw-bold @(Model.Status == HappyChaos.Todo.Models.TaskStatus.Completed ? "text-decoration-line-through text-muted" : "")">
                            @Model.Title
                        </h2>
                        <div class="d-flex flex-wrap gap-2 mt-2">
                            <span class="badge @PriorityBadgeClass(Model.Priority) fs-6">
                                @Model.Priority Priority
                            </span>
                            <span class="badge @StatusBadgeClass(Model.Status) fs-6">
                                @StatusLabel(Model.Status)
                            </span>
                            @if (Model.IsOverdue)
                            {
                                <span class="badge bg-danger fs-6">
                                    <i class="bi bi-alarm me-1"></i>Overdue
                                </span>
                            }
                            else if (Model.IsDueSoon)
                            {
                                <span class="badge bg-warning text-dark fs-6">
                                    <i class="bi bi-clock me-1"></i>Due Soon
                                </span>
                            }
                        </div>
                    </div>
                    <form asp-action="ToggleComplete" asp-route-id="@Model.Id" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn @(Model.Status == HappyChaos.Todo.Models.TaskStatus.Completed ? "btn-success" : "btn-outline-success") d-flex align-items-center gap-2">
                            <i class="bi @(Model.Status == HappyChaos.Todo.Models.TaskStatus.Completed ? "bi-check-circle-fill" : "bi-circle")"></i>
                            @(Model.Status == HappyChaos.Todo.Models.TaskStatus.Completed ? "Mark Incomplete" : "Mark Complete")
                        </button>
                    </form>
                </div>

                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <hr />
                    <div class="mb-0">
                        <h6 class="detail-label">Description</h6>
                        <p class="mb-0" style="white-space: pre-wrap;">@Model.Description</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card mb-3">
            <div class="card-header bg-light fw-semibold">
                <i class="bi bi-info-circle me-2 text-primary"></i>Task Information
            </div>
            <div class="card-body">
                <dl class="mb-0">
                    <dt class="detail-label">Assigned To</dt>
                    <dd class="detail-value mb-3">
                        @if (!string.IsNullOrEmpty(Model.AssignedTo))
                        {
                            <i class="bi bi-person-fill me-1 text-muted"></i>@Model.AssignedTo
                        }
                        else
                        {
                            <span class="text-muted">Unassigned</span>
                        }
                    </dd>

                    <dt class="detail-label">Category</dt>
                    <dd class="detail-value mb-3">
                        @if (!string.IsNullOrEmpty(Model.Category))
                        {
                            <span class="badge bg-secondary-subtle text-secondary border">@Model.Category</span>
                        }
                        else
                        {
                            <span class="text-muted">None</span>
                        }
                    </dd>

                    <dt class="detail-label">Due Date</dt>
                    <dd class="detail-value mb-3">
                        @if (Model.DueDate.HasValue)
                        {
                            var dueCls = Model.IsOverdue ? "due-date-overdue" : Model.IsDueSoon ? "due-date-soon" : "due-date-ok";
                            <span class="@dueCls">
                                <i class="bi bi-calendar-event me-1"></i>@Model.DueDate.Value.ToString("MMMM d, yyyy")
                            </span>
                        }
                        else
                        {
                            <span class="text-muted">No due date</span>
                        }
                    </dd>

                    <dt class="detail-label">Created</dt>
                    <dd class="detail-value mb-3">
                        <i class="bi bi-clock-history me-1 text-muted"></i>
                        @Model.CreatedAt.ToString("MMMM d, yyyy h:mm tt") UTC
                    </dd>

                    <dt class="detail-label">Last Updated</dt>
                    <dd class="detail-value mb-0">
                        <i class="bi bi-clock-history me-1 text-muted"></i>
                        @Model.UpdatedAt.ToString("MMMM d, yyyy h:mm tt") UTC
                    </dd>
                </dl>
            </div>
        </div>

        <div class="d-grid gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary d-flex align-items-center justify-content-center gap-2">
                <i class="bi bi-pencil"></i>Edit Task
            </a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger d-flex align-items-center justify-content-center gap-2">
                <i class="bi bi-trash"></i>Delete Task
            </a>
        </div>
    </div>
</div>
