@model HappyChaos.Todo.Models.TodoTask
@using HappyChaos.Todo.Models
@{
    ViewData["Title"] = "Edit Task";
}

<div class="page-header">
    <div>
        <h1 class="page-title">
            <i class="bi bi-pencil-square me-2" style="color: var(--primary)"></i>Modify Task
        </h1>
        <p class="text-muted mb-0 small">Update task details and status</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary d-flex align-items-center gap-1">
            <i class="bi bi-eye"></i><span>Details</span>
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary d-flex align-items-center gap-1">
            <i class="bi bi-arrow-left"></i><span>Back</span>
        </a>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header" style="background: linear-gradient(135deg, #0891b2, #3b82f6); color: white;">
                <i class="bi bi-pencil me-2"></i>Edit: @Model.Title
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="CreatedAt" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="mb-4">
                        <label asp-for="Title" class="form-label fw-semibold">
                            <i class="bi bi-type me-1 text-muted"></i>Task Title <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Title" class="form-control form-control-lg" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Description" class="form-label fw-semibold">
                            <i class="bi bi-text-paragraph me-1 text-muted"></i>Description
                        </label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-sm-6">
                            <label asp-for="Priority" class="form-label fw-semibold">
                                <i class="bi bi-flag me-1 text-muted"></i>Priority <span class="text-danger">*</span>
                            </label>
                            <select asp-for="Priority" class="form-select"
                                    asp-items="Html.GetEnumSelectList<TaskPriority>()"></select>
                            <span asp-validation-for="Priority" class="text-danger small"></span>
                        </div>
                        <div class="col-sm-6">
                            <label asp-for="Status" class="form-label fw-semibold">
                                <i class="bi bi-activity me-1 text-muted"></i>Status <span class="text-danger">*</span>
                            </label>
                            <select asp-for="Status" class="form-select"
                                    asp-items="Html.GetEnumSelectList<HappyChaos.Todo.Models.TaskStatus>()"></select>
                            <span asp-validation-for="Status" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-sm-6">
                            <label asp-for="DueDate" class="form-label fw-semibold">
                                <i class="bi bi-calendar-event me-1 text-muted"></i>Due Date
                            </label>
                            <input asp-for="DueDate" class="form-control" type="date" />
                            <span asp-validation-for="DueDate" class="text-danger small"></span>
                        </div>
                        <div class="col-sm-6">
                            <label asp-for="AssignedTo" class="form-label fw-semibold">
                                <i class="bi bi-person me-1 text-muted"></i>Assigned To
                            </label>
                            <input asp-for="AssignedTo" class="form-control" placeholder="e.g. Team, Alice, Bob" />
                            <span asp-validation-for="AssignedTo" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Category" class="form-label fw-semibold">
                            <i class="bi bi-tag me-1 text-muted"></i>Category
                        </label>
                        <input asp-for="Category" class="form-control" placeholder="e.g. Backend, Frontend, DevOps" />
                        <span asp-validation-for="Category" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-3 pt-2">
                        <button type="submit" class="btn btn-primary btn-lg d-flex align-items-center gap-2">
                            <i class="bi bi-check-lg"></i>
                            Save Changes
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary btn-lg">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card mb-3">
            <div class="card-header bg-light">
                <i class="bi bi-info-circle me-2 text-primary"></i>Task Info
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-5 detail-label">Created</dt>
                    <dd class="col-7 detail-value">@Model.CreatedAt.ToString("MMM d, yyyy")</dd>
                    <dt class="col-5 detail-label">Updated</dt>
                    <dd class="col-7 detail-value">@Model.UpdatedAt.ToString("MMM d, yyyy")</dd>
                    <dt class="col-5 detail-label">Task ID</dt>
                    <dd class="col-7 detail-value">#@Model.Id</dd>
                </dl>
            </div>
        </div>
        <div class="d-grid">
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger d-flex align-items-center justify-content-center gap-2">
                <i class="bi bi-trash"></i>
                Delete This Task
            </a>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
